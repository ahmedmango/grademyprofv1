# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App
NEXT_PUBLIC_APP_URL=https://grademyprofessor.bh
NEXT_PUBLIC_APP_NAME=GradeMyProfessor

# Admin auth (simple shared secret for MVP — replace with proper auth later)
ADMIN_SECRET=change-me-to-a-long-random-string

# Session & admin JWT signing keys (generate with: openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-random-string
ADMIN_JWT_SECRET=change-me-to-a-random-string

# Sentry — error monitoring (get from sentry.io → Create Project → Next.js)
# NEXT_PUBLIC_ prefix exposes DSN to the browser (intentional — DSN is not a secret)
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=sntrys_...   # For source map uploads — add to Vercel only, never commit

# Upstash Redis — distributed rate limiting (get from upstash.com → Create Database → REST API)
# Without these, rate limiting falls back to in-process memory (resets on cold start)
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# Feature flags
NEXT_PUBLIC_REGISTRATION_MODE=false
NEXT_PUBLIC_SHOW_REWARDS=true
NEXT_PUBLIC_ENABLE_SHARE=true
